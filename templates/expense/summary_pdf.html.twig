<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
body { font-family: DejaVu Sans, sans-serif; font-size: 12px; color: #111; margin: 30px; }
h1 { font-size: 20px; color: #4f46e5; margin-bottom: 4px; }
.sub { color: #6b7280; font-size: 12px; margin-bottom: 24px; }
table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
th { background: #f3f4f6; text-align: left; padding: 6px 8px; font-size: 11px; }
td { padding: 5px 8px; border-bottom: 1px solid #f3f4f6; }
.total-row td { font-weight: bold; background: #eef2ff; font-size: 14px; }
.section-title { font-size: 13px; font-weight: bold; color: #374151; margin: 16px 0 6px; }
.footer { font-size: 10px; color: #9ca3af; margin-top: 20px; }
</style>
</head>
<body>

<h1>Recapitulatif Frais Reels - {{ year }}</h1>
<div class="sub">Genere le {{ "now"|date("d/m/Y") }} - Annee {{ year }}</div>

<p class="section-title">Deductions par categorie</p>
<table>
  <tr><th>Categorie</th><th>Detail</th><th>Deduction</th></tr>
  <tr>
    <td>Trajets</td>
    <td>{{ data.travel.trips|length }} trajets - {{ data.travel.totalKm|round(0) }} km</td>
    <td>{{ data.travel.deduction|number_format(2, ',', ' ') }} €</td>
  </tr>
  <tr>
    <td>Teletravail</td>
    <td>{{ data.remoteWork.days }} jours x {{ data.remoteWork.dailyAllowance|number_format(2, ',', ' ') }} EUR</td>
    <td>{{ data.remoteWork.deduction|number_format(2, ',', ' ') }} €</td>
  </tr>
  <tr>
    <td>Peages</td>
    <td>{{ data.toll.entries }} entrees</td>
    <td>{{ data.toll.deduction|number_format(2, ',', ' ') }} €</td>
  </tr>
  {% if data.meal.entries > 0 %}
  <tr>
    <td>Repas professionnels</td>
    <td>{{ data.meal.entries }} repas − {{ data.meal.homeMealValue|number_format(2, ',', ' ') }} EUR/repas</td>
    <td>{{ data.meal.deduction|number_format(2, ',', ' ') }} €</td>
  </tr>
  {% endif %}
  {% if data.parking.entries > 0 %}
  <tr>
    <td>Parking</td>
    <td>{{ data.parking.entries }} entrees</td>
    <td>{{ data.parking.deduction|number_format(2, ',', ' ') }} €</td>
  </tr>
  {% endif %}
  <tr class="total-row">
    <td colspan="2">Total deductible {{ year }}</td>
    <td>{{ data.total|number_format(2, ',', ' ') }} €</td>
  </tr>
</table>

{% if data.travel.trips|length > 0 %}
<p class="section-title">Detail des trajets</p>
<table>
  <tr><th>Date</th><th>Trajet</th><th>Distance</th><th>Puissance</th></tr>
  {% for trip in data.travel.trips %}
  <tr>
    <td>{{ trip.date }}</td>
    <td>
      {% if trip.departure and trip.arrival %}
        {{ trip.departure }} → {{ trip.arrival }}
      {% else %}
        {{ trip.description ?? '—' }}
      {% endif %}
      {% if trip.roundTrip %} (A/R){% endif %}
    </td>
    <td>{{ trip.distanceKm }} km</td>
    <td>{{ trip.vehiclePower ?? '—' }} CV</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

<p class="footer">Calcule selon le bareme kilometrique officiel {{ year }}. Document a conserver en cas de controle fiscal.</p>

</body>
</html>